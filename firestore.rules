rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Función para verificar si el usuario es administrador
    // Asumiendo que guardas un campo 'role': 'admin' en el documento del usuario
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. Colección de Usuarios (users)
    match /users/{userId} {
      // Un usuario puede leer y escribir su propio documento
      allow read, update: if isAuthenticated() && request.auth.uid == userId;
      // Permitir la creación al registrarse
      allow create: if isAuthenticated();
      // Un administrador puede leer y modificar cualquier usuario
      allow read, write: if isAdmin();
    }

    // 2. Colección de Vehículos (vehicles) - Catálogo
    match /vehicles/{vehicleId} {
      // Cualquier persona (incluso sin login) puede ver los vehículos
      allow read: if true;
      // Solo un administrador puede agregar, modificar o eliminar vehículos
      allow write: if isAdmin();
    }

    // 3. Colección de Órdenes o Carrito (orders)
    match /orders/{orderId} {
      // Un usuario solo puede ver sus propias órdenes
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Un usuario puede crear una orden si está autenticado
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Un administrador puede ver y actualizar todas las órdenes
      allow read, write: if isAdmin();
    }
    
    // Denegar cualquier otro acceso por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
